# API keys for the litellm-backed judge fallback path.
# Leave any blank to disable that judge family.
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GOOGLE_API_KEY=

# vLLM server URL if you run judges as a hosted server rather than in-process.
DIFFUJUDGE_VLLM_URL=

# Path overrides — defaults are project-relative.
DIFFUJUDGE_DATA_DIR=./data
DIFFUJUDGE_OUTPUT_DIR=./outputs
DIFFUJUDGE_CACHE_DIR=./.cache

# Determinism.
DIFFUJUDGE_SEED=42
